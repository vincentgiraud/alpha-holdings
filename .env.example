# Data source configuration
DATA_SOURCE=yahoo  # yahoo, stooq
FALLBACK_DATA_SOURCE=stooq

# Storage configuration
DATA_STORAGE_PATH=./data
DATABASE_URL=duckdb:///./alpha.duckdb

# Provider selection
ENABLE_EDGAR=true
ENABLE_FRED=true

# Benchmark configuration
BENCHMARK_SYMBOL=SPY
BENCHMARK_PROXY_EQUITY=SPY
BENCHMARK_PROXY_BOND=BND

# Portfolio defaults (can be overridden by InvestorProfile)
DEFAULT_MAX_POSITION_SIZE=0.05
DEFAULT_SECTOR_DEVIATION=0.05
DEFAULT_COUNTRY_DEVIATION=0.05
DEFAULT_MAX_ANNUAL_TURNOVER=0.50
DEFAULT_MIN_HOLDINGS=30
DEFAULT_MAX_PORTFOLIO_VOLATILITY=0.15

# Rebalance schedule
REBALANCE_CADENCE=monthly  # daily, weekly, monthly, quarterly
REBALANCE_DAY_OF_WEEK=Monday  # for weekly
REBALANCE_DAY_OF_MONTH=1  # for monthly
REBALANCE_MONTH_AND_DAY=January-1  # for quarterly

# Analysis configuration
ANALYSIS_LOOKBACK_DAYS=252
CONFIDENCE_LEVEL=0.95

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
